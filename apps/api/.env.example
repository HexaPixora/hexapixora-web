# ── Core ────────────────────────────────────────────────────────────────────
# API server port
PORT=3001

# Comma-separated list of browser origins allowed to call the API directly.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Postgres connection string (also consumed by packages/database).
DATABASE_URL=postgresql://user:password@localhost:5432/hexapixora

# JWT signing secrets — REQUIRED in production (the API refuses to start without
# them when NODE_ENV=production). Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# ── First-admin bootstrap (seed) ─────────────────────────────────────────────
# Used by `npm run db:seed --workspace=@repo/database`. Idempotent.
# Leave the password blank to skip seeding.
SEED_ADMIN_EMAIL=admin@hexapixora.com
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Administrator

# ── Draft preview ─────────────────────────────────────────────────────────────
# Shared server-to-server secret for Draft Mode preview of unpublished/scheduled
# content. MUST match the web app's PREVIEW_TOKEN. Unset = preview disabled.
PREVIEW_TOKEN=

# ── Media storage (Supabase Storage — free 1GB) ──────────────────────────────
# When BOTH are set, uploads persist to a PUBLIC Supabase Storage bucket
# (survives Railway redeploys). When unset, media falls back to the local
# ./uploads disk (fine for local dev, but ephemeral on Railway).
# SUPABASE_URL = https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY = Supabase dashboard → Settings → API → service_role
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=media

# ── Transactional email (Resend — free tier) ─────────────────────────────────
# All optional: with no key the MailService no-ops and lead capture still works.
RESEND_API_KEY=
MAIL_FROM=HexaPixora <onboarding@resend.dev>
LEADS_NOTIFY_TO=

# ── Support-chat AI (OpenAI-compatible; Groq free tier by default) ────────────
# Optional: with no key the bot stays silent and chats route to the team.
# Swap providers by overriding AI_BASE_URL/AI_MODEL (Gemini, local Ollama, …).
AI_API_KEY=
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile
