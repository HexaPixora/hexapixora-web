# Postgres connection string used by Prisma (push, studio, seed).
# Local dev: a plain localhost string is fine.
# Hosted on a pooler (e.g. Supabase session pooler): append ?connection_limit=5
# so Prisma doesn't exhaust the pooler's small client limit.
DATABASE_URL=postgresql://user:password@localhost:5432/hexapixora

# First-admin bootstrap for `npm run db:seed --workspace=@repo/database`.
# Idempotent: creates a SUPER_ADMIN only if this email doesn't exist yet.
# Leave SEED_ADMIN_PASSWORD blank to skip seeding entirely.
SEED_ADMIN_EMAIL=admin@hexapixora.com
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Administrator
