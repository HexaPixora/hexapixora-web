datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// User & Authentication
// ==========================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  // Null until an INVITED user accepts their invite and sets a password.
  password  String?
  name      String?
  role      Role     @default(TEAM_MEMBER)
  // Account lifecycle: INVITED users can't log in until they accept + set a password.
  status    UserStatus @default(ACTIVE)
  // Section keys this user may access (e.g. ["blogs","media"]). Ignored for
  // ADMIN/SUPER_ADMIN, who have full access. Drives TEAM_MEMBER capabilities.
  permissions String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions  Session[]
  auditLogs AuditLog[]
  assignedConversations Conversation[]
  chatMessages          ChatMessage[]
  chatNotes             ConversationNote[]
  verificationTokens VerificationToken[]
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TEAM_MEMBER
}

enum UserStatus {
  ACTIVE
  INVITED
}

// Single-use magic-link tokens for invites, password resets and email changes.
model VerificationToken {
  id        String    @id @default(uuid())
  token     String    @unique
  type      TokenType
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Target address for EMAIL_CHANGE (the pending new email).
  newEmail  String?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([userId])
}

enum TokenType {
  INVITE
  PASSWORD_RESET
  EMAIL_CHANGE
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  details   Json?
  createdAt DateTime @default(now())
}

// ==========================================
// CMS Modules
// ==========================================

model Service {
  id               String   @id @default(uuid())
  title            String
  slug             String   @unique
  icon             String?
  banner           String?
  excerpt          String?
  content          String
  features         Json?    // Array of strings or objects
  faq              Json?    // Array of { question, answer }
  
  // SEO
  metaTitle        String?
  metaDescription  String?
  metaKeywords     String?
  ogImage          String?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Portfolio {
  id               String   @id @default(uuid())
  title            String
  slug             String   @unique
  clientName       String?
  industry         String?
  description      String
  challenge        String?
  solution         String?
  results          String?
  technologies     Json?    // Array of strings
  gallery          Json?    // Array of media URLs
  
  // SEO
  metaTitle        String?
  metaDescription  String?
  metaKeywords     String?
  ogImage          String?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// Publishing lifecycle shared by Page and Blog. DRAFT = not public; SCHEDULED =
// goes live automatically once publishAt passes (a cron flips it to PUBLISHED);
// PUBLISHED = visible on the live site.
enum ContentStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
}

// Shared content taxonomy. Curated in the admin (distinct from free-form `tags`)
// and referenced by blog posts (many-to-many) and the portfolio module (by name).
model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  color       String?  // optional hex for admin/badge tinting
  blogs       Blog[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Blog {
  id               String   @id @default(uuid())
  title            String
  slug             String   @unique
  excerpt          String?
  categories       Category[]
  tags             Json?    // Array of strings
  thumbnail        String?
  content          String
  publishDate      DateTime?
  isPublished      Boolean  @default(false)
  // Richer publishing state. Kept in sync with isPublished by BlogsService
  // (isPublished stays the canonical public filter). Legacy rows default to
  // DRAFT — backfill once with: UPDATE "Blog" SET status='PUBLISHED' WHERE "isPublished"=true;
  status           ContentStatus @default(DRAFT)
  // When set with status=SCHEDULED, the publish cron makes the post live at this time.
  publishAt        DateTime?
  readTime         Int?     // Minutes to read, auto-calculated
  
  // SEO
  metaTitle        String?
  metaDescription  String?
  metaKeywords     String?
  ogImage          String?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TeamMember {
  id               String   @id @default(uuid())
  name             String
  designation      String
  bio              String?
  image            String?
  linkedinUrl      String?
  githubUrl        String?
  order            Int      @default(0)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Faq {
  id               String   @id @default(uuid())
  question         String
  answer           String
  category         String?
  order            Int      @default(0)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Media {
  id               String   @id @default(uuid())
  filename         String
  url              String
  mimetype         String
  size             Int
  folder           String?  @default("general")
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ==========================================
// Marketing & Leads
// ==========================================

model Lead {
  id               String   @id @default(uuid())
  name             String
  email            String
  phone            String?
  message          String?
  type             String   @default("contact") // contact, consultation, quote, chat
  status           LeadStatus @default(NEW)

  conversations    Conversation[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
}

model NewsletterSubscriber {
  id               String   @id @default(uuid())
  email            String   @unique
  status           SubscriptionStatus @default(ACTIVE)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum SubscriptionStatus {
  ACTIVE
  UNSUBSCRIBED
}

// ==========================================
// Site Settings & Configuration
// ==========================================

model SiteSetting {
  id               String   @id @default("global") // Single row pattern
  siteName         String   @default("HexaPixora")
  tagline          String?
  businessEmail    String?
  businessPhone    String?
  address          String?
  timezone         String?
  googleMapsUrl    String?
  logoUrl          String?
  faviconUrl       String?
  
  // Analytics
  googleAnalyticsId String?
  gtmId            String?
  metaPixelId      String?

  // Scheduling / booking — list of meeting types: [{ label, url }] (Calendly etc.)
  bookingLinks     Json     @default("[{\"label\":\"Free Strategy Call\",\"url\":\"https://calendly.com/umairbreet/free-strategy-call\"}]")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model LayoutConfig {
  id               String   @id @default(uuid())
  key              String   @unique // 'header', 'footer', 'mega-menu'
  data             Json     // Storing nested configurations
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ==========================================
// Custom Pages
// ==========================================

model Page {
  id               String   @id @default(uuid())
  title            String
  slug             String   @unique
  sections         Json     @default("[]") // Array of modules
  showHeader       Boolean  @default(true)
  showFooter       Boolean  @default(true)
  // Exactly one page may be the site home (rendered at "/"). Enforced in the
  // service (setting one clears the others); indexed for the public lookup.
  isHomepage       Boolean  @default(false)
  // Publishing lifecycle. Defaults to PUBLISHED so existing pages stay live
  // after the column is added; new pages may be saved as DRAFT/SCHEDULED.
  status           ContentStatus @default(PUBLISHED)
  // When set with status=SCHEDULED, the publish cron makes the page live at this time.
  publishAt        DateTime?
  metaTitle        String?
  metaDescription  String?
  // Featured / social-share image (Open Graph + Twitter card).
  ogImage          String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([isHomepage])
}

// ==========================================
// AI Support Chat ("HexaPixora Support AI")
// ==========================================

// Single-row ("global") admin-managed configuration for the public chat widget.
model ChatbotConfig {
  id               String   @id @default("global")
  enabled          Boolean  @default(true)
  botName          String   @default("HexaPixora Support AI")
  welcomeMessage   String   @default("Hi! I'm the HexaPixora Support AI. How can I help you today?")
  // Extra guidance appended to the auto-generated, services-scoped system prompt.
  systemPrompt     String?
  aiEnabled        Boolean  @default(true)
  // OpenAI-compatible model name. The endpoint + API key live in env, never the
  // DB. Default targets Groq's free tier; change it if you override AI_BASE_URL
  // (e.g. a Gemini or Ollama model name).
  aiModel          String   @default("llama-3.3-70b-versatile")
  accentColor      String   @default("#4f46e5")
  // Shown when AI is off / unconfigured and no agent is available.
  offlineMessage   String   @default("Thanks for your message! Our team will get back to you by email shortly.")
  // Encourage the AI to collect name/email and create a CRM lead.
  collectLeads     Boolean  @default(true)
  // Quick-reply chips shown in the widget. Array of { label, reply? }: a chip
  // with a `reply` answers instantly with that text; without one it sends the
  // label to the AI.
  quickReplies     Json     @default("[{\"label\":\"What services do you offer?\"},{\"label\":\"How much does a website cost?\"},{\"label\":\"I'd like to start a project\"}]")

  // ---- Widget appearance / behavior ----
  // "bottom-right" | "bottom-left"
  position         String   @default("bottom-right")
  // Launcher + header icon: message-circle | message-square | bot | sparkles | headset
  launcherIcon     String   @default("message-circle")
  // Subtitle under the bot name in the header.
  headerSubtitle   String   @default("Typically replies instantly")
  // Show the "Talk to a human" button.
  showAgentHandoff Boolean  @default(true)
  // Identity shown in the header once a team member takes the chat over.
  teamName         String   @default("Support Team")
  // Header subtitle shown once a team member takes the chat over.
  teamSubtitle     String   @default("A team member is here to help")
  // Optional custom image (URL) used as the launcher/header icon. Overrides
  // launcherIcon when set.
  launcherIconUrl  String?
  // Auto-delete conversations whose last activity is older than this many days.
  // 0 = keep forever.
  retentionDays    Int      @default(0)
  // Agent-only saved replies. Array of { title, text } inserted via "/" in the
  // inbox composer. Not exposed to visitors.
  cannedReplies    Json     @default("[]")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum ConversationStatus {
  BOT            // AI is handling the conversation
  WAITING_AGENT  // Visitor asked for / needs a human; queued for the team
  AGENT          // A team member has taken over
  CLOSED
}

model Conversation {
  id            String             @id @default(uuid())
  // Opaque token the anonymous visitor uses to authorize their own messages.
  visitorToken  String             @unique
  visitorName   String?
  visitorEmail  String?
  status        ConversationStatus @default(BOT)

  // Team member who took the conversation over, if any.
  assignedToId  String?
  assignedTo    User?              @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  // CRM lead created/linked from this conversation (lead qualification).
  leadId        String?
  lead          Lead?              @relation(fields: [leadId], references: [id], onDelete: SetNull)

  // Last time a visitor message went unanswered-by-agent — drives inbox badges.
  unreadForAgent Boolean           @default(false)
  lastMessageAt  DateTime          @default(now())

  messages      ChatMessage[]
  notes         ConversationNote[]

  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([status, lastMessageAt])
}

enum ChatRole {
  USER    // The website visitor
  AI      // The bot
  AGENT   // A human team member
  SYSTEM  // System notices (e.g. "Agent joined")
}

model ChatMessage {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           ChatRole
  content        String
  // Set when role = AGENT — which team member sent it.
  senderId       String?
  sender         User?        @relation(fields: [senderId], references: [id], onDelete: SetNull)

  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// Internal team-only notes on a conversation (never shown to the visitor).
model ConversationNote {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  content        String
  authorId       String?
  author         User?        @relation(fields: [authorId], references: [id], onDelete: SetNull)

  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// ==========================================
// Admin Notifications (in-app bell feed)
// ==========================================

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  body      String?
  // Admin deep-link to the related record, e.g. "/admin/leads" or "/admin/chat/123".
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([read])
  @@index([createdAt])
}

enum NotificationType {
  LEAD
  CHAT_HANDOFF
  CHAT_MESSAGE
  NEWSLETTER
  SYSTEM
}
